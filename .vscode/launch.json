            // "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            // "environment": [],
            // "externalConsole": false,
            // "MIMode": "lldb",
            // "miDebuggerPath": "/usr/bin/lldb",
            // "setupCommands": [
            //     {
            //         "description": "Enable pretty-printing for gdb",
            //         "text": "-enable-pretty-printing",
            //         "ignoreFailures": true
            //     }
            // ],
            "preLaunchTask": "cmake: build"
        },
    ],
    "inputs": [
        {
            "id": "packageName",
